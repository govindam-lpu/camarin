# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
# Loud default exists for dev; production refuses to boot with the default.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# ── Infrastructure ───────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/mediapipeline
REDIS_URL=redis://localhost:6379

# ── Upload limits ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5

# ── File storage ─────────────────────────────────────────────────────────────
# local = disk (docker-compose shares a volume between api & worker)
# s3    = any S3-compatible endpoint (GCS w/ HMAC keys, R2, B2, MinIO)
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./data/uploads
# Required only when STORAGE_DRIVER=s3:
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# ── AI pipeline ──────────────────────────────────────────────────────────────
# mock = deterministic fake providers, zero keys needed (default; great for local review)
# real = Hugging Face (caption) + Google Cloud Vision (labels + SafeSearch)
AI_PROVIDER=mock
# How to obtain (see README):
#   HF_TOKEN:    huggingface.co -> Settings -> Access Tokens -> new "Read" token
#   GCV_API_KEY: console.cloud.google.com -> enable "Cloud Vision API" -> Credentials -> API key
HF_TOKEN=
HF_CAPTION_URL=https://router.huggingface.co/hf-inference/models/Salesforce/blip-image-captioning-base
GCV_API_KEY=
GCV_ENDPOINT=https://vision.googleapis.com/v1/images:annotate
AI_TIMEOUT_MS=45000

# ── Worker tuning ────────────────────────────────────────────────────────────
# Parallel jobs per worker process; scale processes with `docker compose up --scale worker=N`
WORKER_CONCURRENCY=4
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=3000
MOCK_DELAY_MS=900

LOG_LEVEL=info
