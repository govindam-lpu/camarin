{
  "info": {
    "name": "Darkroom — AI Media Processing API",
    "description": "All endpoints for the AI media processing microservice.\n\nSetup:\n1. Set the `baseUrl` collection variable (default http://localhost:8080; or use the live deployment).\n2. Run **Auth → Signup** (or **Login**) — the JWT is saved automatically to the `token` variable and used by every other request.\n3. Run **Jobs → Upload image** with a file selected — the returned job id is saved to `jobId` for the detail/retry/image calls.\n\nThe OpenAPI spec (server/openapi.yaml, live Swagger UI at /api/docs) is the source of truth; this collection is a convenience wrapper.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "jobId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reviewer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "signup"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reviewer@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
        {
          "name": "Me (session restore)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Upload image",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('jobId', pm.response.json().job.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "JPG/PNG/WEBP, max 5MB. (In mock mode, name it flagme.png / failme.png / flaky.png / badreq.png to exercise those flows.)"
                }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/jobs", "host": ["{{baseUrl}}"], "path": ["api", "jobs"] }
          }
        },
        {
          "name": "List jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "completed", "disabled": true },
                { "key": "flagged", "value": "true", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get job (full results)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}"] }
          }
        },
        {
          "name": "Retry failed job",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/retry", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "retry"] }
          }
        },
        {
          "name": "Get job image",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/jobs/{{jobId}}/image", "host": ["{{baseUrl}}"], "path": ["api", "jobs", "{{jobId}}", "image"] }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List notifications",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/notifications", "host": ["{{baseUrl}}"], "path": ["api", "notifications"] }
          }
        },
        {
          "name": "Mark all read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"all\": true\n}" },
            "url": { "raw": "{{baseUrl}}/api/notifications/read", "host": ["{{baseUrl}}"], "path": ["api", "notifications", "read"] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
      }
    }
  ]
}
